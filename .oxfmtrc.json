{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "bracketSpacing": true,
    "endOfLine": "lf",
    "htmlWhitespaceSensitivity": "ignore",
    "printWidth": 120,
    "proseWrap": "always",
    "semi": true,
    "singleAttributePerLine": true,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "all",
    "useTabs": false,
    "experimentalSortPackageJson": false
}
